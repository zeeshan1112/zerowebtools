{
  "manifest_version": 3,
  "name": "ZeelanceBox - Developer Utility Tools",
  "version": "0.1.0",
  "description": "Free developer utility tools: JSON formatter, case converter, and more. All processing runs locally in the browser.",
  "permissions": [],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ZeelanceBox Tools",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}