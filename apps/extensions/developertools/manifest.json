{
  "manifest_version": 3,
  "name": "ZeroWebTools - Developer Utilities",
  "version": "0.1.0",
  "description": "Free developer utility tools: JSON formatter, case converter, and more. All processing runs locally in the browser.",
  "permissions": [],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ZeroWebTools",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "developertools@zerowebtools.com",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}