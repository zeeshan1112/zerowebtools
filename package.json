{
  "name": "zerowebtools",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "build:web": "npm run build --workspace=apps/web",
    "build:tools-core": "npm run build --workspace=@hub/tools-core",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "dependencies": {
    "@pdfsmaller/pdf-encrypt-lite": "^1.0.2",
    "heic-to": "^1.4.3",
    "heic2any": "^0.0.4",
    "jszip": "^3.10.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.7.284"
  }
}
